---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBox from '../components/AuthorBox.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { formatDate, formatDateISO, getCategoryInfo, SITE } from '../utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  tags?: string[];
  author?: string;
  readingTime?: number;
  pillar?: boolean;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt = title,
  category,
  tags = [],
  author = SITE.author,
  readingTime,
  pillar = false,
  slug,
} = Astro.props;

const catInfo = getCategoryInfo(category);
const canonicalURL = new URL(`/blog/${slug}`, SITE.url).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "url": `${SITE.url}`,
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE.title,
    "url": SITE.url,
  },
  "datePublished": formatDateISO(pubDate),
  ...(updatedDate && { "dateModified": formatDateISO(updatedDate) }),
  ...(heroImage && { "image": new URL(heroImage, SITE.url).href }),
  "mainEntityOfPage": canonicalURL,
  "keywords": tags.join(', '),
  "articleSection": catInfo.name,
  "inLanguage": "pl-PL",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE.url}/blog` },
    { "@type": "ListItem", "position": 3, "name": catInfo.name, "item": `${SITE.url}/kategoria/${category}` },
    { "@type": "ListItem", "position": 4, "name": title, "item": canonicalURL },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage || SITE.ogImage}
  ogType="article"
  canonicalURL={canonicalURL}
  jsonLd={articleSchema}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <meta property="article:published_time" content={formatDateISO(pubDate)} />
    {updatedDate && <meta property="article:modified_time" content={formatDateISO(updatedDate)} />}
    <meta property="article:author" content={author} />
    <meta property="article:section" content={catInfo.name} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <ReadingProgress />

  <div class="container">
    <Breadcrumbs items={[
      { label: 'Blog', href: '/blog' },
      { label: catInfo.name, href: `/kategoria/${category}` },
      { label: title },
    ]} />
  </div>

  <article class="article" itemscope itemtype="https://schema.org/Article">
    <header class="article-header">
      <div class="container container--prose">
        <div class="post-card__meta" style="justify-content:center; margin-bottom: var(--space-4);">
          <a
            href={`/kategoria/${category}`}
            class="post-card__category"
            style={`background: ${catInfo.color}15; color: ${catInfo.color};`}
          >
            {catInfo.icon} {catInfo.name}
          </a>
          {pillar && <span class="pillar-badge">📖 Pillar Page</span>}
        </div>
        <h1 itemprop="headline">{title}</h1>
        <div class="article-meta">
          <span class="article-meta__item" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
            <span itemprop="name">{author}</span>
          </span>
          <span class="article-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <time datetime={formatDateISO(pubDate)} itemprop="datePublished">{formatDate(pubDate)}</time>
          </span>
          {updatedDate && (
            <span class="article-meta__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
              <time datetime={formatDateISO(updatedDate)} itemprop="dateModified">Zaktualizowano: {formatDate(updatedDate)}</time>
            </span>
          )}
          {readingTime && (
            <span class="article-meta__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              {readingTime} min czytania
            </span>
          )}
        </div>
      </div>
    </header>

    {heroImage && (
      <div class="article-hero-img container">
        <img
          src={heroImage}
          alt={heroImageAlt}
          width="960"
          height="411"
          loading="eager"
          itemprop="image"
        />
      </div>
    )}

    <div class="container container--prose">
      <div class="prose" itemprop="articleBody">
        <slot />
      </div>

      {tags.length > 0 && (
        <div style="margin-top: var(--space-8); display: flex; flex-wrap: wrap; gap: var(--space-2);">
          {tags.map(tag => (
            <span class="tag"># {tag}</span>
          ))}
        </div>
      )}

      <AuthorBox />
    </div>

    <div class="container">
      <RelatedPosts category={category} currentSlug={slug} />
    </div>
  </article>
</BaseLayout>
